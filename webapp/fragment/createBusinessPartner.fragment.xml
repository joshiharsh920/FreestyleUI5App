<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="createBPDialog" title="Create Business Partner" stretch="true">

        <content>
            <VBox class="sapUiSmallMargin">

                <Input id="bpId" placeholder="BP ID" />
                <Input id="companyName" placeholder="Company Name" />
                <Input id="email" placeholder="Email" />
                <Input id="phone" placeholder="Phone" />

                <Input id="city" placeholder="City" />
                <Input id="country" placeholder="Country" />
                <Input id="street" placeholder="Street" />

            </VBox>
        </content>

        <beginButton>
            <Button text="Create" type="Emphasized" press="onCreateSubmit"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press="onCreateCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>