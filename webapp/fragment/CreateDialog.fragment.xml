<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog title="Create Order" id="createDialog">

        <VBox class="sapUiSmallMargin">

            <Input placeholder="Order ID" value="{new>/Orderid}" />
            <Input placeholder="Customer ID" value="{new>/Customerid}" />
            <Input placeholder="Customer Name" value="{new>/Customername}" />
            <Input placeholder="Status" value="{new>/Orderstatus}" />
            <Input placeholder="Address" value="{new>/Address}" />

        </VBox>

        <beginButton>
            <Button text="Create" type="Emphasized" press="onCreate"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press="onCloseDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>