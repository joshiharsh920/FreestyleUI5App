<mvc:View controllerName="joshi.project1trial.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.f">
    <Page id='page1'>
     <customHeader>
             <Toolbar>
        <ToolbarSpacer/>
        <Title text="Learning Application" level="H1"/>
        <ToolbarSpacer/>
    </Toolbar>
    </customHeader>
<IconTabHeader mode="Inline">
    <items>
        <IconTabFilter key="info" text="Info" />
        <IconTabFilter key="attachments" text="Attachments" count="3" />
        <IconTabFilter key="notes" text="Notes" count="12" />
        <IconTabFilter key="people" text="People"/>
    </items>
</IconTabHeader>
 <FlexBox
  wrap="Wrap"
  justifyContent="Start"
  alignItems="Start"
  renderType="Div">

  <items>
    <GenericTile
      class="sapUiSmallMargin"
      header="Customers"
      press="onTilePress" />

    <GenericTile
      class="sapUiSmallMargin"
      header="Orders"
      press="onTilePress" />
  </items>

</FlexBox>
    </Page>
</mvc:View>

