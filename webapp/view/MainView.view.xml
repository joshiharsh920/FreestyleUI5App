<mvc:View controllerName="joshi.project1trial.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">
    <Page id='page1'>
     <customHeader>
             <Toolbar>
        <ToolbarSpacer/>
        <Title text="Invenio Application" level="H1"/>
        <ToolbarSpacer/>
    </Toolbar>
    </customHeader>
<IconTabHeader
    mode="Inline"
    select="onTabSelect"
    items="{
        path: 'tabsModel>/'
    }">

    <items>
        <IconTabFilter
            key="{tabsModel>ObjectId}"
            text="{tabsModel>TabText}"
            count="{tabsModel>TabCount}"
            icon="{tabsModel>TabIcon}"
            visible="{= ${tabsModel>IsVisible} === 'Y'}" />
    </items>

</IconTabHeader>
 <FlexBox
    wrap="Wrap"
    justifyContent="Start"
    alignItems="Start"
    items="{
        path: 'tileModel>/'
    }">
    <items>
        <GenericTile
            class="sapUiSmallMargin"
            header="{tileModel>TileTitle}"
            press="onTilePress">

            <tileContent>
                <TileContent>
                      <content>
                            <VBox>
                    <core:Icon
                        src="{tileModel>Icon}"
                        size="2rem" />

                    <Text text="{tileModel>TileCount}" />
                </VBox>
                        </content>

                </TileContent>
            </tileContent>

        </GenericTile>
    </items>
</FlexBox>
    </Page>
</mvc:View>

