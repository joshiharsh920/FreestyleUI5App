    <Page id='page1'>
     <customHeader>
             <Toolbar>
        <ToolbarSpacer/>
        <Title text="Learning Application" level="H1"/>
        <ToolbarSpacer/>
    </Toolbar>
    </customHeader>
  <mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f">

 <FlexBox
  wrap="Wrap"
  justifyContent="Start"
  alignItems="Start"
